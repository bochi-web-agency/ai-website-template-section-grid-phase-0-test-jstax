---
import Base from "../layouts/Base.astro";
---

<Base title="Contact Us | J&S Tax Accountants">
  <!-- Hero / Page Banner -->
  <section
    id="hero"
    class="relative bg-blue-900 text-white py-20 px-4 text-center overflow-hidden"
  >
    <div class="absolute inset-0 bg-blue-950/60"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-blue-300 uppercase tracking-widest text-sm font-semibold mb-3">
        Get In Touch
      </p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 leading-tight">
        Contact Us
      </h1>
      <p class="text-blue-100 text-lg max-w-xl mx-auto">
        Have questions about your taxes or accounting needs? Our friendly team
        at J&amp;S Tax Accountants is here to help. Reach out today.
      </p>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section id="contact-info" class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 text-center mb-12">
        How to Reach Us
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: Address -->
        <div class="flex flex-col items-center text-center bg-blue-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blue-900 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">Our Office</h3>
          <p class="text-gray-600 leading-relaxed">
            123 Finance Avenue, Suite 400<br />
            Melbourne, VIC 3000<br />
            Australia
          </p>
        </div>

        <!-- Card 2: Phone -->
        <div class="flex flex-col items-center text-center bg-blue-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blue-900 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">Phone</h3>
          <p class="text-gray-600 leading-relaxed">
            <a href="tel:+61391234567" class="text-blue-700 hover:text-blue-900 font-medium transition-colors">
              (03) 9123 4567
            </a>
          </p>
          <p class="text-gray-500 text-sm mt-2">Mon – Fri: 9:00 AM – 5:30 PM</p>
        </div>

        <!-- Card 3: Email -->
        <div class="flex flex-col items-center text-center bg-blue-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-blue-900 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">Email</h3>
          <p class="text-gray-600 leading-relaxed">
            <a href="mailto:info@jstaxaccountants.com" class="text-blue-700 hover:text-blue-900 font-medium transition-colors">
              info@jstaxaccountants.com
            </a>
          </p>
          <p class="text-gray-500 text-sm mt-2">We reply within 1 business day</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form + Map -->
  <section id="contact-form" class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Form -->
      <div class="bg-white rounded-2xl shadow-md p-8 md:p-10">
        <h2 class="text-2xl font-bold text-blue-900 mb-2">Send Us a Message</h2>
        <p class="text-gray-500 mb-8 text-sm">
          Fill in the form below and one of our tax professionals will be in touch shortly.
        </p>
        <form class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">
                First Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                placeholder="Jane"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">
                Last Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                placeholder="Smith"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              Email Address <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="jane@example.com"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
              Phone Number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="04XX XXX XXX"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition"
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-medium text-gray-700 mb-1">
              Service Enquiry
            </label>
            <select
              id="service"
              name="service"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-700 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition"
            >
              <option value="">— Select a service —</option>
              <option value="tax-return">Individual Tax Return</option>
              <option value="business-tax">Business Tax &amp; BAS</option>
              <option value="bookkeeping">Bookkeeping</option>
              <option value="smsf">SMSF Administration</option>
              <option value="advisory">Financial Advisory</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
              Message <span class="text-red-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us how we can help you..."
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-blue-900 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors duration-200 text-sm tracking-wide"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Map Placeholder + Hours -->
      <div class="flex flex-col gap-8">
        <!-- Map -->
        <div class="rounded-2xl overflow-hidden shadow-md h-72 bg-gray-200 relative">
          <img
            src="/images/placeholder.jpg"
            alt="Office location map"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 flex items-center justify-center bg-blue-900/40">
            <span class="bg-white text-blue-900 font-bold px-5 py-2 rounded-full text-sm shadow">
              📍 123 Finance Avenue, Melbourne
            </span>
          </div>
        </div>

        <!-- Business Hours -->
        <div class="bg-white rounded-2xl shadow-md p-8">
          <h3 class="text-xl font-bold text-blue-900 mb-5">Business Hours</h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex justify-between border-b border-gray-100 pb-3">
              <span class="font-medium">Monday – Friday</span>
              <span class="text-blue-800 font-semibold">9:00 AM – 5:30 PM</span>
            </li>
            <li class="flex justify-between border-b border-gray-100 pb-3">
              <span class="font-medium">Saturday</span>
              <span class="text-blue-800 font-semibold">10:00 AM – 2:00 PM</span>
            </li>
            <li class="flex justify-between">
              <span class="font-medium">Sunday</span>
              <span class="text-red-500 font-semibold">Closed</span>
            </li>
          </ul>
          <p class="text-gray-500 text-xs mt-5">
            * Extended hours available during tax season (July – October). Please call ahead to confirm.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Contact Us / Assurance Strip -->
  <section id="assurance" class="bg-blue-900 text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10">
        Why Clients Trust J&amp;S Tax Accountants
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div class="bg-blue-800 rounded-xl p-6 hover:bg-blue-700 transition-colors">
          <div class="text-4xl font-extrabold text-yellow-400 mb-2">20+</div>
          <p class="text-blue-100 text-sm leading-snug">Years of tax &amp; accounting experience</p>
        </div>
        <div class="bg-blue-800 rounded-xl p-6 hover:bg-blue-700 transition-colors">
          <div class="text-4xl font-extrabold text-yellow-400 mb-2">5,000+</div>
          <p class="text-blue-100 text-sm leading-snug">Tax returns lodged annually</p>
        </div>
        <div class="bg-blue-800 rounded-xl p-6 hover:bg-blue-700 transition-colors">
          <div class="text-4xl font-extrabold text-yellow-400 mb-2">CPA</div>
          <p class="text-blue-100 text-sm leading-snug">Certified &amp; registered tax agents</p>
        </div>
        <div class="bg-blue-800 rounded-xl p-6 hover:bg-blue-700 transition-colors">
          <div class="text-4xl font-extrabold text-yellow-400 mb-2">100%</div>
          <p class="text-blue-100 text-sm leading-snug">Satisfaction guarantee on every job</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 text-center mb-3">
        What Our Clients Say
      </h2>
      <p class="text-gray-500 text-center mb-12 max-w-xl mx-auto text-sm">
        Hundreds of individuals and small businesses trust us with their tax affairs every year.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-blue-50 rounded-2xl p-7 shadow-sm flex flex-col">
          <div class="flex text-yellow-400 mb-4 gap-0.5">
            {Array(5).fill(null).map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-5">
            "J&amp;S Tax Accountants made my tax return so easy. They found
            deductions I never knew I was entitled to and lodged everything
            quickly. Highly recommend!"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-200 flex items-center justify-center font-bold text-blue-900 text-sm">
              LM
            </div>
            <div>
              <p class="font-semibold text-blue-900 text-sm">Laura M.</p>
              <p class="text-gray-400 text-xs">Small Business Owner</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-blue-50 rounded-2xl p-7 shadow-sm flex flex-col">
          <div class="flex text-yellow-400 mb-4 gap-0.5">
            {Array(5).fill(null).map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-5">
            "Professional, thorough, and always on time. The team at J&amp;S
            has handled our company's BAS and payroll for three years without
            a single issue."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-200 flex items-center justify-center font-bold text-blue-900 text-sm">
              RP
            </div>
            <div>
              <p class="font-semibold text-blue-900 text-sm">Robert P.</p>
              <p class="text-gray-400 text-xs">Company Director</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-blue-50 rounded-2xl p-7 shadow-sm flex flex-col">
          <div class="flex text-yellow-400 mb-4 gap-0.5">
            {Array(5).fill(null).map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-5">
            "Switched to J&amp;S after years with another firm and the
            difference is night and day. Friendly, knowledgeable staff who
            actually explain your options."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-200 flex items-center justify-center font-bold text-blue-900 text-sm">
              SK
            </div>
            <div>
              <p class="font-semibold text-blue-900 text-sm">Sara K.</p>
              <p class="text-gray-400 text-xs">Sole Trader</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section id="cta" class="bg-yellow-400 py-14 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-4">
        Ready to Get Started?
      </h2>
      <p class="text-blue-800 mb-8 text-base leading-relaxed">
        Book a free 30-minute consultation with one of our registered tax agents.
        No obligation — just expert advice tailored to your situation.
      </p>
      <a
        href="tel:+61391234567"
        class="inline-block bg-blue-900 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-full transition-colors duration-200 text-sm tracking-wide shadow-lg"
      >
        Call Us Now: (03) 9123 4567
      </a>
    </div>
  </section>
</Base>