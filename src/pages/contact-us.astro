---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "contact-us");
const { title, description, meta_title, meta_image, hero_title, hero_content, hero_cta } = entry.data;
---

<Base title={meta_title || title} description={description}>

  <!-- Hero Section -->
  <section id="hero" class="relative bg-blue-900 text-white py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        {hero_title}
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-2xl mx-auto mb-8">
        {hero_content}
      </p>
      {hero_cta && (
        <a
          href={hero_cta.url}
          class="inline-block bg-yellow-400 text-blue-900 font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors duration-200"
        >
          {hero_cta.label}
        </a>
      )}
    </div>
    <div class="absolute inset-0 opacity-10 bg-[url('/images/placeholder.jpg')] bg-cover bg-center -z-0 rounded"></div>
  </section>

  <!-- Contact Info + Form Section -->
  <section id="contact-main" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Contact Details -->
      <div class="space-y-8">
        <div>
          <h2 class="text-3xl font-bold text-blue-900 mb-2">Get in Touch</h2>
          <p class="text-gray-600">
            We'd love to hear from you. Whether you have a question about our services, pricing, or anything else — our team is ready to answer all your questions.
          </p>
        </div>

        <!-- Office Address -->
        <div class="flex items-start gap-4">
          <div class="shrink-0 bg-blue-100 text-blue-900 rounded-full p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-blue-900">Our Office</h3>
            <p class="text-gray-600">123 Tax Lane, Suite 200<br />Springfield, IL 62701</p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="shrink-0 bg-blue-100 text-blue-900 rounded-full p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-blue-900">Phone</h3>
            <a href="tel:+12175550100" class="text-gray-600 hover:text-blue-700 transition-colors">(217) 555-0100</a>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="shrink-0 bg-blue-100 text-blue-900 rounded-full p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-blue-900">Email</h3>
            <a href="mailto:info@jstaxaccountants.com" class="text-gray-600 hover:text-blue-700 transition-colors">info@jstaxaccountants.com</a>
          </div>
        </div>

        <!-- Business Hours -->
        <div class="flex items-start gap-4">
          <div class="shrink-0 bg-blue-100 text-blue-900 rounded-full p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-blue-900">Business Hours</h3>
            <p class="text-gray-600">Monday – Friday: 9:00 AM – 6:00 PM<br />Saturday: 10:00 AM – 2:00 PM<br />Sunday: Closed</p>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-gray-50 rounded-2xl p-8 shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold text-blue-900 mb-6">Send Us a Message</h2>
        <form class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
              <input
                type="text"
                id="first-name"
                name="first_name"
                placeholder="Jane"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
              <input
                type="text"
                id="last-name"
                name="last_name"
                placeholder="Smith"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="jane@example.com"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="(217) 555-0100"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Interested In</label>
            <select
              id="service"
              name="service"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white"
            >
              <option value="" disabled selected>Select a service…</option>
              <option value="tax-preparation">Tax Preparation</option>
              <option value="tax-planning">Tax Planning</option>
              <option value="bookkeeping">Bookkeeping</option>
              <option value="payroll">Payroll Services</option>
              <option value="business-consulting">Business Consulting</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us how we can help you…"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-blue-900 hover:bg-blue-800 text-white font-semibold py-3 rounded-lg transition-colors duration-200"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Map / Location Section -->
  <section id="map" class="bg-gray-100 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-900 mb-2">Find Us</h2>
        <p class="text-gray-600">Conveniently located in downtown Springfield — easy parking available.</p>
      </div>
      <div class="w-full h-80 rounded-2xl overflow-hidden shadow-md bg-gray-200 flex items-center justify-center">
        <img
          src="/images/placeholder.jpg"
          alt="Map showing J&S Tax Accountants office location"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Why Contact Us / Quick Reasons -->
  <section id="reasons" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-blue-900 mb-3">Why Work With Us?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          J&S Tax Accountants has been serving individuals and small businesses for over 20 years. Here's why clients trust us:
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
            title: "Trusted Experts",
            body: "Over two decades of tax and accounting experience serving Springfield and the surrounding area.",
          },
          {
            icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
            title: "Transparent Pricing",
            body: "No hidden fees. We provide clear, upfront pricing so you always know exactly what you're paying for.",
          },
          {
            icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
            title: "Personalized Service",
            body: "Every client gets dedicated attention. We tailor our approach to your unique financial situation.",
          },
          {
            icon: "M13 10V3L4 14h7v7l9-11h-7z",
            title: "Fast Turnaround",
            body: "We respect your time. Expect prompt responses and efficient processing of all your tax documents.",
          },
          {
            icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
            title: "Year-Round Support",
            body: "We're here for you beyond tax season — available year-round for questions, planning, and advice.",
          },
          {
            icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
            title: "Comprehensive Services",
            body: "From individual returns to full business accounting, we offer a complete suite of tax and financial services.",
          },
        ].map((item) => (
          <div class="bg-blue-50 rounded-xl p-6 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="bg-blue-900 text-white rounded-full w-12 h-12 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-blue-900">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section id="cta-bottom" class="bg-blue-900 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-blue-100 text-lg mb-8">
        Don't wait until tax season is upon you. Reach out today and let J&S Tax Accountants put your financial future on the right track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+12175550100"
          class="inline-block bg-yellow-400 text-blue-900 font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors duration-200"
        >
          Call Us Now
        </a>
        <a
          href="mailto:info@jstaxaccountants.com"
          class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-full hover:bg-white hover:text-blue-900 transition-colors duration-200"
        >
          Email Us
        </a>
      </div>
    </div>
  </section>

</Base>