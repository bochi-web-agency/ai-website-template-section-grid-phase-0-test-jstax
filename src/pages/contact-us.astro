---
import Base from "../layouts/Base.astro";
---

<Base title="Contact Us | J&S Tax Accountants">
  <!-- Hero / Page Banner -->
  <section
    id="hero"
    class="relative bg-gradient-to-br from-blue-900 to-blue-700 text-white py-20 px-6"
  >
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-blue-300 uppercase tracking-widest text-sm font-semibold mb-3">
        Get In Touch
      </p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">
        Have a question about your taxes or accounting needs? We're here to
        help. Reach out and one of our friendly experts will get back to you
        promptly.
      </p>
    </div>
    <!-- Decorative wave -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
      <svg
        viewBox="0 0 1440 60"
        xmlns="http://www.w3.org/2000/svg"
        class="w-full h-12 text-white fill-white"
      >
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z"></path>
      </svg>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section id="contact-info" class="py-16 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card: Address -->
        <div
          class="flex flex-col items-center text-center bg-gray-50 border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow"
        >
          <div
            class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mb-5"
          >
            <svg
              class="w-7 h-7 text-blue-700"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Our Office</h3>
          <p class="text-gray-500 leading-relaxed">
            123 Main Street, Suite 400<br />Sydney, NSW 2000<br />Australia
          </p>
        </div>

        <!-- Card: Phone -->
        <div
          class="flex flex-col items-center text-center bg-gray-50 border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow"
        >
          <div
            class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mb-5"
          >
            <svg
              class="w-7 h-7 text-blue-700"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Phone</h3>
          <p class="text-gray-500 leading-relaxed">
            <a href="tel:+61299990000" class="hover:text-blue-700 transition-colors">
              (02) 9999 0000
            </a>
          </p>
          <p class="text-sm text-gray-400 mt-1">Mon – Fri, 9 am – 5 pm</p>
        </div>

        <!-- Card: Email -->
        <div
          class="flex flex-col items-center text-center bg-gray-50 border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow"
        >
          <div
            class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mb-5"
          >
            <svg
              class="w-7 h-7 text-blue-700"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Email</h3>
          <p class="text-gray-500 leading-relaxed">
            <a
              href="mailto:info@jstaxaccountants.com"
              class="hover:text-blue-700 transition-colors"
            >
              info@jstaxaccountants.com
            </a>
          </p>
          <p class="text-sm text-gray-400 mt-1">We reply within 24 hours</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form + Map -->
  <section id="contact-form" class="py-16 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Form -->
        <div class="bg-white rounded-2xl shadow-md p-8 md:p-10">
          <h2 class="text-2xl font-bold text-gray-800 mb-2">Send Us a Message</h2>
          <p class="text-gray-500 mb-8">
            Fill out the form below and a member of our team will be in touch
            shortly.
          </p>
          <form class="space-y-6" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label
                  for="first-name"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  First Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  placeholder="Jane"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                />
              </div>
              <div>
                <label
                  for="last-name"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Last Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  placeholder="Smith"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                />
              </div>
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="jane@example.com"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(02) 9999 0000"
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="service"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Service Enquiry
              </label>
              <select
                id="service"
                name="service"
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="" disabled selected>Select a service…</option>
                <option>Individual Tax Return</option>
                <option>Business Tax Return</option>
                <option>BAS / GST Lodgement</option>
                <option>Bookkeeping</option>
                <option>Self-Managed Super Fund (SMSF)</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us how we can help you…"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-700 hover:bg-blue-800 text-white font-semibold py-3 px-8 rounded-lg transition-colors duration-200 focus:outline-none focus:ring-4 focus:ring-blue-300"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Map placeholder + Business Hours -->
        <div class="space-y-8">
          <!-- Map -->
          <div class="rounded-2xl overflow-hidden shadow-md">
            <img
              src="/images/placeholder.jpg"
              alt="Map location of J&S Tax Accountants"
              class="w-full h-72 object-cover"
            />
          </div>

          <!-- Business Hours -->
          <div class="bg-white rounded-2xl shadow-md p-8">
            <h3 class="text-xl font-bold text-gray-800 mb-5 flex items-center gap-2">
              <svg
                class="w-5 h-5 text-blue-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Business Hours
            </h3>
            <ul class="space-y-3">
              {
                [
                  { day: "Monday", hours: "9:00 am – 5:00 pm" },
                  { day: "Tuesday", hours: "9:00 am – 5:00 pm" },
                  { day: "Wednesday", hours: "9:00 am – 5:00 pm" },
                  { day: "Thursday", hours: "9:00 am – 5:00 pm" },
                  { day: "Friday", hours: "9:00 am – 5:00 pm" },
                  { day: "Saturday", hours: "By appointment only" },
                  { day: "Sunday", hours: "Closed" },
                ].map(({ day, hours }) => (
                  <li class="flex justify-between text-sm border-b border-gray-100 pb-2 last:border-0 last:pb-0">
                    <span class="font-medium text-gray-700">{day}</span>
                    <span
                      class={
                        hours === "Closed"
                          ? "text-red-400 font-medium"
                          : "text-gray-500"
                      }
                    >
                      {hours}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Contact Us / Quick Reasons -->
  <section id="why-us" class="py-16 px-6 bg-blue-700 text-white">
    <div class="max-w-5xl mx-auto text-center mb-12">
      <h2 class="text-3xl font-bold mb-3">Why Work With J&S Tax Accountants?</h2>
      <p class="text-blue-200 max-w-2xl mx-auto">
        We make tax time stress-free. Here's what you can expect when you get
        in touch with us.
      </p>
    </div>
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      {
        [
          {
            icon: "✅",
            title: "Fast Response",
            desc: "We aim to reply to all enquiries within one business day.",
          },
          {
            icon: "💼",
            title: "Expert Advice",
            desc: "Registered tax agents with years of real-world experience.",
          },
          {
            icon: "🔒",
            title: "100% Confidential",
            desc: "Your financial information is always kept strictly private.",
          },
          {
            icon: "💲",
            title: "Transparent Pricing",
            desc: "No hidden fees — we quote upfront before any work begins.",
          },
        ].map(({ icon, title, desc }) => (
          <div class="bg-blue-800 rounded-xl p-6 text-center">
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="text-lg font-semibold mb-2">{title}</h3>
            <p class="text-blue-200 text-sm leading-relaxed">{desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ Snippet -->
  <section id="faq" class="py-16 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-3">
          Frequently Asked Questions
        </h2>
        <p class="text-gray-500">
          Quick answers to the questions we hear most often.
        </p>
      </div>
      <div class="space-y-4">
        {
          [
            {
              q: "How do I book an appointment?",
              a: "You can contact us via the form above, call our office on (02) 9999 0000, or email us directly. We'll arrange a time that suits you — in-person or via video call.",
            },
            {
              q: "What documents should I bring to my first appointment?",
              a: "For individuals: your PAYG payment summaries, bank statements, private health insurance statement, and any receipts for deductions. We'll provide a full checklist after you book.",
            },
            {
              q: "Do you offer services remotely?",
              a: "Absolutely. We regularly assist clients Australia-wide via phone, email, and video conferencing, so you don't need to visit our office in person.",
            },
            {
              q: "How long does a tax return take?",
              a: "Most individual returns are completed within 3–5 business days of receiving all required documents. Business returns may take longer depending on complexity.",
            },
          ].map(({ q, a }) => (
            <details class="group border border-gray-200 rounded-xl overflow-hidden">
              <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-medium text-gray-800 hover:bg-gray-50 transition-colors list-none">
                {q}
                <svg
                  class="w-5 h-5 text-blue-600 transition-transform group-open:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </summary>
              <div class="px-6 pb-5 text-gray-500 text-sm leading-relaxed border-t border-gray-100 pt-4">
                {a}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section
    id="cta"
    class="py-14 px-6 bg-gradient-to-r from-blue-800 to-blue-600 text-white text-center"
  >
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Ready to Take Control of Your Taxes?</h2>
      <p class="text-blue-100 mb-8 text-lg">
        Book a free, no-obligation consultation with one of our friendly tax
        accountants today.
      </p>
      <a
        href="tel:+61299990000"
        class="inline-block bg-white text-blue-800 font-bold py-3 px-10 rounded-full hover:bg-blue-50 transition-colors shadow-md"
      >
        Call (02) 9999 0000
      </a>
    </div>
  </section>
</Base>