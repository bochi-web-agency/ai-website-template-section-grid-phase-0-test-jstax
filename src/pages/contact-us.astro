---
import Base from "../layouts/Base.astro";
---

<Base title="Contact Us | J&S Tax Accountants">
  <!-- Hero / Page Header -->
  <section
    id="hero"
    class="relative bg-blue-900 text-white py-20 px-4 text-center"
  >
    <div class="max-w-3xl mx-auto">
      <p class="text-blue-300 uppercase tracking-widest text-sm font-semibold mb-3">
        Get In Touch
      </p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-blue-200 text-lg max-w-xl mx-auto">
        Have a question about your taxes or accounting needs? We're here to
        help. Reach out to our team today and we'll get back to you promptly.
      </p>
    </div>
    <!-- Decorative wave -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
      <svg
        viewBox="0 0 1440 48"
        xmlns="http://www.w3.org/2000/svg"
        class="w-full h-12 text-white fill-white"
      >
        <path d="M0,48 L1440,0 L1440,48 Z"></path>
      </svg>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section id="contact-info" class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: Address -->
        <div class="flex flex-col items-center text-center bg-gray-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-blue-900 text-white rounded-full p-4 mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Our Office</h3>
          <p class="text-gray-600 leading-relaxed">
            123 Financial District Blvd<br />
            Suite 400<br />
            Houston, TX 77002
          </p>
        </div>

        <!-- Card 2: Phone -->
        <div class="flex flex-col items-center text-center bg-gray-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-blue-900 text-white rounded-full p-4 mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Phone & Fax</h3>
          <p class="text-gray-600 leading-relaxed">
            <a href="tel:+17135550192" class="hover:text-blue-800 transition-colors">
              Phone: (713) 555-0192
            </a><br />
            <span>Fax: (713) 555-0193</span>
          </p>
          <p class="text-sm text-gray-400 mt-3">Mon – Fri: 9 AM – 6 PM CST</p>
        </div>

        <!-- Card 3: Email -->
        <div class="flex flex-col items-center text-center bg-gray-50 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-blue-900 text-white rounded-full p-4 mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Email Us</h3>
          <p class="text-gray-600 leading-relaxed">
            <a
              href="mailto:info@jstaxaccountants.com"
              class="hover:text-blue-800 transition-colors break-all"
            >
              info@jstaxaccountants.com
            </a>
          </p>
          <p class="text-sm text-gray-400 mt-3">
            We respond within 1 business day
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form + Map -->
  <section id="contact-form" class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Form -->
        <div class="bg-white rounded-2xl shadow-sm p-8 md:p-10">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">
            Send Us a Message
          </h2>
          <p class="text-gray-500 mb-8">
            Fill out the form below and one of our tax professionals will be
            in touch shortly.
          </p>

          <form class="space-y-5" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label
                  for="first-name"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  First Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  placeholder="Jane"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition"
                />
              </div>
              <div>
                <label
                  for="last-name"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Last Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  placeholder="Smith"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition"
                />
              </div>
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="jane@example.com"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(713) 000-0000"
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition"
              />
            </div>

            <div>
              <label
                for="service"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Service Interested In
              </label>
              <select
                id="service"
                name="service"
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition"
              >
                <option value="" disabled selected>Select a service…</option>
                <option value="individual-tax">Individual Tax Preparation</option>
                <option value="business-tax">Business Tax Preparation</option>
                <option value="bookkeeping">Bookkeeping Services</option>
                <option value="payroll">Payroll Services</option>
                <option value="irs-representation">IRS Representation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-gray-700 mb-1"
              >
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us a bit about your situation or question…"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-700 focus:border-transparent transition resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-900 hover:bg-blue-800 text-white font-semibold py-3 px-8 rounded-lg transition-colors duration-200 text-base"
            >
              Send Message
            </button>

            <p class="text-xs text-gray-400 text-center">
              Your information is secure and will never be shared with third
              parties.
            </p>
          </form>
        </div>

        <!-- Map + Hours -->
        <div class="space-y-8">
          <!-- Map Placeholder -->
          <div class="rounded-2xl overflow-hidden shadow-sm">
            <img
              src="/images/placeholder.jpg"
              alt="Office location map"
              class="w-full h-72 object-cover"
            />
            <div class="bg-blue-900 text-white px-6 py-4 flex items-center gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
              </svg>
              <span class="text-sm font-medium">
                123 Financial District Blvd, Suite 400, Houston, TX 77002
              </span>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="bg-white rounded-2xl shadow-sm p-8">
            <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-blue-900"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
              Business Hours
            </h3>
            <ul class="space-y-3 text-sm">
              {[
                { day: "Monday", hours: "9:00 AM – 6:00 PM" },
                { day: "Tuesday", hours: "9:00 AM – 6:00 PM" },
                { day: "Wednesday", hours: "9:00 AM – 6:00 PM" },
                { day: "Thursday", hours: "9:00 AM – 6:00 PM" },
                { day: "Friday", hours: "9:00 AM – 5:00 PM" },
                { day: "Saturday", hours: "10:00 AM – 2:00 PM" },
                { day: "Sunday", hours: "Closed" },
              ].map(({ day, hours }) => (
                <li class="flex justify-between border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                  <span class="font-medium text-gray-700">{day}</span>
                  <span
                    class={hours === "Closed" ? "text-red-500" : "text-gray-600"}
                  >
                    {hours}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us / Quick Facts -->
  <section id="why-us" class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto text-center mb-12">
      <p class="text-blue-700 uppercase tracking-widest text-sm font-semibold mb-2">
        Why Work With Us
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800">
        Trusted Tax Professionals You Can Count On
      </h2>
    </div>
    <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        {
          icon: "🏆",
          title: "20+ Years Experience",
          desc: "Serving individuals and businesses with expert tax guidance since 2003.",
        },
        {
          icon: "🔒",
          title: "Confidential & Secure",
          desc: "Your financial data is handled with the highest level of privacy and security.",
        },
        {
          icon: "📞",
          title: "Year-Round Support",
          desc: "We're available beyond tax season to answer questions and provide guidance.",
        },
        {
          icon: "✅",
          title: "Certified Professionals",
          desc: "Our CPAs and tax specialists stay current on the latest tax laws and regulations.",
        },
      ].map(({ icon, title, desc }) => (
        <div class="text-center bg-gray-50 rounded-2xl p-7 hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">{icon}</div>
          <h3 class="text-base font-bold text-gray-800 mb-2">{title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section
    id="cta"
    class="bg-blue-900 text-white py-16 px-4 text-center"
  >
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to Get Started?
      </h2>
      <p class="text-blue-200 text-lg mb-8">
        Schedule a free consultation today and let our experts handle your tax
        and accounting needs with confidence.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+17135550192"
          class="inline-block bg-white text-blue-900 font-semibold px-8 py-3 rounded-lg hover:bg-blue-100 transition-colors duration-200"
        >
          Call (713) 555-0192
        </a>
        <a
          href="mailto:info@jstaxaccountants.com"
          class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-lg hover:bg-white hover:text-blue-900 transition-colors duration-200"
        >
          Email Us
        </a>
      </div>
    </div>
  </section>
</Base>