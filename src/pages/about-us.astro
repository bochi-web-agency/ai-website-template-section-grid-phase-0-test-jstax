---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "about-us");
const { title, description, meta_title, meta_image, hero_title, hero_content, hero_cta } = entry.data;
---

<Base title={meta_title || title} description={description}>

  <!-- Hero Section -->
  <section id="hero" class="relative bg-blue-900 text-white py-24 px-6 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-950 via-blue-900 to-blue-800 opacity-95"></div>
    <div class="relative max-w-5xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {hero_title}
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-3xl mx-auto mb-8 leading-relaxed">
        {hero_content}
      </p>
      {hero_cta && (
        <a
          href={hero_cta.url}
          class="inline-block bg-yellow-400 hover:bg-yellow-300 text-blue-900 font-semibold px-8 py-3 rounded-md transition-colors duration-200 text-lg shadow-md"
        >
          {hero_cta.label}
        </a>
      )}
    </div>
  </section>

  <!-- Who We Are Section -->
  <section id="who-we-are" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-yellow-500 font-semibold uppercase tracking-widest text-sm mb-3">Who We Are</p>
        <h2 class="text-3xl md:text-4xl font-bold text-blue-900 mb-5 leading-tight">
          Trusted Tax Professionals Serving Families &amp; Businesses
        </h2>
        <p class="text-gray-600 mb-4 leading-relaxed">
          J&amp;S Tax Accountants was founded with a simple mission: to make expert tax preparation and financial planning accessible to every individual, family, and small business in our community. With decades of combined experience, our team is dedicated to delivering accurate, timely, and personalized service.
        </p>
        <p class="text-gray-600 mb-4 leading-relaxed">
          Whether you're filing a personal return, managing payroll, or navigating the complexities of business taxes, we bring deep knowledge and genuine care to every engagement. We believe in building long-term relationships based on trust and transparency.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Our office stays current with the latest IRS regulations and state tax laws so you don't have to — giving you peace of mind year-round, not just at tax season.
        </p>
      </div>
      <div class="rounded-xl overflow-hidden shadow-xl">
        <img
          src="/images/placeholder.jpg"
          alt="J&S Tax Accountants office"
          class="w-full h-80 object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section id="our-values" class="py-20 px-6 bg-blue-50">
    <div class="max-w-6xl mx-auto text-center mb-14">
      <p class="text-yellow-500 font-semibold uppercase tracking-widest text-sm mb-3">Our Core Values</p>
      <h2 class="text-3xl md:text-4xl font-bold text-blue-900">What Drives Everything We Do</h2>
    </div>
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        {
          icon: "🤝",
          title: "Integrity",
          body: "We operate with complete honesty. Every recommendation we make is in your best interest — no upsells, no hidden fees, no surprises.",
        },
        {
          icon: "🎯",
          title: "Accuracy",
          body: "Precision is non-negotiable in our work. We double-check every return and report to ensure compliance and maximize your outcomes.",
        },
        {
          icon: "💬",
          title: "Communication",
          body: "We keep you informed at every step. You'll always know what's happening with your taxes and why — in plain language you can understand.",
        },
        {
          icon: "🔒",
          title: "Confidentiality",
          body: "Your financial information is treated with the highest level of security and discretion. We protect your data like it's our own.",
        },
        {
          icon: "📅",
          title: "Reliability",
          body: "Deadlines matter. We plan ahead, keep promises, and deliver your filings on time — every single time.",
        },
        {
          icon: "🌱",
          title: "Growth",
          body: "We're committed to continuous learning. Our team regularly trains on new tax code changes so we can always give you the best advice.",
        },
      ].map((value) => (
        <div class="bg-white rounded-xl p-7 shadow-sm hover:shadow-md transition-shadow duration-200 text-left">
          <div class="text-4xl mb-4">{value.icon}</div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{value.title}</h3>
          <p class="text-gray-600 leading-relaxed text-sm">{value.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Team Section -->
  <section id="our-team" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto text-center mb-14">
      <p class="text-yellow-500 font-semibold uppercase tracking-widest text-sm mb-3">Meet the Team</p>
      <h2 class="text-3xl md:text-4xl font-bold text-blue-900">The People Behind Your Returns</h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto">
        Our professionals bring decades of expertise in tax law, accounting, and financial planning. We're not just your accountants — we're your partners.
      </p>
    </div>
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {[
        { name: "James Stafford, CPA", role: "Founder & Senior Tax Advisor", years: "28 years experience" },
        { name: "Sandra Reyes, EA", role: "Enrolled Agent & Tax Specialist", years: "15 years experience" },
        { name: "Michael Chen, CPA", role: "Business Tax Consultant", years: "12 years experience" },
      ].map((member) => (
        <div class="text-center group">
          <div class="w-40 h-40 rounded-full overflow-hidden mx-auto mb-5 shadow-md ring-4 ring-blue-100 group-hover:ring-yellow-400 transition-all duration-200">
            <img
              src="/images/placeholder.jpg"
              alt={member.name}
              class="w-full h-full object-cover"
            />
          </div>
          <h3 class="text-lg font-bold text-blue-900">{member.name}</h3>
          <p class="text-yellow-600 font-medium text-sm mb-1">{member.role}</p>
          <p class="text-gray-400 text-xs">{member.years}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Stats Section -->
  <section id="stats" class="py-20 px-6 bg-blue-900 text-white">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 text-center">
      {[
        { number: "20+", label: "Years in Business" },
        { number: "5,000+", label: "Returns Filed" },
        { number: "98%", label: "Client Satisfaction" },
        { number: "500+", label: "Small Business Clients" },
      ].map((stat) => (
        <div>
          <p class="text-4xl md:text-5xl font-extrabold text-yellow-400 mb-2">{stat.number}</p>
          <p class="text-blue-200 text-sm uppercase tracking-wide">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section id="why-us" class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="rounded-xl overflow-hidden shadow-xl order-2 md:order-1">
        <img
          src="/images/placeholder.jpg"
          alt="Why choose J&S Tax"
          class="w-full h-80 object-cover"
        />
      </div>
      <div class="order-1 md:order-2">
        <p class="text-yellow-500 font-semibold uppercase tracking-widest text-sm mb-3">Why Choose Us</p>
        <h2 class="text-3xl md:text-4xl font-bold text-blue-900 mb-6 leading-tight">
          More Than Just a Tax Preparer
        </h2>
        <ul class="space-y-4">
          {[
            "Year-round support — not just during tax season",
            "IRS representation if you're ever audited",
            "Personalized strategies to minimize your tax burden legally",
            "Bilingual staff available for Spanish-speaking clients",
            "Secure online document submission for your convenience",
            "Flat-rate pricing with no hidden fees",
          ].map((item) => (
            <li class="flex items-start gap-3 text-gray-700">
              <span class="mt-1 flex-shrink-0 w-5 h-5 bg-yellow-400 rounded-full flex items-center justify-center">
                <svg class="w-3 h-3 text-blue-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto text-center mb-14">
      <p class="text-yellow-500 font-semibold uppercase tracking-widest text-sm mb-3">Client Stories</p>
      <h2 class="text-3xl md:text-4xl font-bold text-blue-900">What Our Clients Are Saying</h2>
    </div>
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
      {[
        {
          quote: "J&S Tax has been handling our business taxes for six years. They always find deductions we'd never think of and file everything on time. Absolutely worth every penny.",
          name: "Robert M.",
          detail: "Small Business Owner",
        },
        {
          quote: "I was nervous about an IRS audit notice, but the team handled everything professionally and the matter was resolved quickly. I felt completely supported throughout.",
          name: "Angela T.",
          detail: "Individual Client",
        },
        {
          quote: "Switching to J&S was the best financial decision I made. They explained everything clearly and I got a much larger refund than I expected. Highly recommend!",
          name: "Carlos V.",
          detail: "Freelance Consultant",
        },
      ].map((t) => (
        <div class="bg-blue-50 rounded-xl p-7 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow duration-200">
          <p class="text-gray-700 italic leading-relaxed mb-6">"{t.quote}"</p>
          <div>
            <p class="font-bold text-blue-900">{t.name}</p>
            <p class="text-yellow-600 text-sm">{t.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section id="cta" class="py-20 px-6 bg-yellow-400">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-blue-900 mb-4">
        Ready to Work with a Team You Can Trust?
      </h2>
      <p class="text-blue-800 text-lg mb-8">
        Schedule a free consultation today and discover how J&amp;S Tax Accountants can help you keep more of what you earn.
      </p>
      <a
        href="/contact-us"
        class="inline-block bg-blue-900 hover:bg-blue-800 text-white font-semibold px-10 py-4 rounded-md transition-colors duration-200 text-lg shadow-md"
      >
        Book a Free Consultation
      </a>
    </div>
  </section>

</Base>