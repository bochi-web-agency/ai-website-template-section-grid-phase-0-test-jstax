---
import Base from "../layouts/Base.astro";
---

<Base title="About Us | J&S Tax Accountants">
  <!-- Hero / Page Banner -->
  <section
    id="hero"
    class="relative bg-blue-900 text-white py-24 px-6 text-center overflow-hidden"
  >
    <div class="absolute inset-0 opacity-20">
      <img
        src="/images/placeholder.jpg"
        alt=""
        class="w-full h-full object-cover"
      />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-blue-300 uppercase tracking-widest text-sm font-semibold mb-3">
        Who We Are
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
        About J&amp;S Tax Accountants
      </h1>
      <p class="text-blue-100 text-lg leading-relaxed">
        Trusted accounting and tax professionals serving individuals and
        businesses with integrity, expertise, and personalized service.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section id="our-story" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/images/placeholder.jpg"
          alt="Our office team"
          class="w-full h-80 object-cover"
        />
      </div>
      <div>
        <p class="text-blue-600 uppercase tracking-widest text-sm font-semibold mb-2">
          Our Story
        </p>
        <h2 class="text-3xl font-bold text-gray-800 mb-4">
          Built on Trust &amp; Decades of Experience
        </h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          J&amp;S Tax Accountants was founded with a clear mission: to provide
          high-quality, reliable accounting and tax services to individuals,
          families, and businesses of all sizes. Over the years, we have grown
          into a respected firm known for our meticulous attention to detail and
          our commitment to our clients' financial success.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Our team brings together decades of combined experience in tax
          preparation, bookkeeping, payroll, and financial consulting. Whether
          you're filing a simple return or navigating a complex business
          structure, we have the expertise to guide you every step of the way.
        </p>
        <div class="flex gap-8">
          <div>
            <span class="text-4xl font-extrabold text-blue-700">20+</span>
            <p class="text-gray-500 text-sm mt-1">Years in Business</p>
          </div>
          <div>
            <span class="text-4xl font-extrabold text-blue-700">1,500+</span>
            <p class="text-gray-500 text-sm mt-1">Clients Served</p>
          </div>
          <div>
            <span class="text-4xl font-extrabold text-blue-700">98%</span>
            <p class="text-gray-500 text-sm mt-1">Client Satisfaction</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section id="values" class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto text-center mb-14">
      <p class="text-blue-600 uppercase tracking-widest text-sm font-semibold mb-2">
        What Drives Us
      </p>
      <h2 class="text-3xl font-bold text-gray-800">Our Mission &amp; Core Values</h2>
      <p class="text-gray-500 mt-3 max-w-xl mx-auto">
        Everything we do is guided by a commitment to honesty, accuracy, and
        putting our clients first.
      </p>
    </div>
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        {
          icon: "⚖️",
          title: "Integrity",
          desc: "We operate with complete transparency and honesty in every engagement, large or small.",
        },
        {
          icon: "🎯",
          title: "Accuracy",
          desc: "Precision is non-negotiable. We double-check every figure to ensure flawless filings.",
        },
        {
          icon: "🤝",
          title: "Client-First",
          desc: "Your financial goals are our priority. We tailor our approach to fit your unique situation.",
        },
        {
          icon: "📚",
          title: "Continuous Learning",
          desc: "Tax laws change constantly. Our team stays current so you never miss a benefit.",
        },
        {
          icon: "🔒",
          title: "Confidentiality",
          desc: "We treat your personal and financial information with the highest level of discretion.",
        },
        {
          icon: "💡",
          title: "Proactive Advice",
          desc: "We don't just file returns — we identify opportunities to save you money year-round.",
        },
      ].map((v) => (
        <div class="bg-white rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">{v.icon}</div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">{v.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Meet the Team -->
  <section id="team" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto text-center mb-14">
      <p class="text-blue-600 uppercase tracking-widest text-sm font-semibold mb-2">
        The People Behind the Numbers
      </p>
      <h2 class="text-3xl font-bold text-gray-800">Meet Our Team</h2>
      <p class="text-gray-500 mt-3 max-w-xl mx-auto">
        A dedicated group of certified professionals passionate about helping
        you achieve financial clarity and confidence.
      </p>
    </div>
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { name: "James Sullivan", role: "Founder & Senior CPA", years: "22 yrs exp." },
        { name: "Sandra Torres", role: "Tax Director", years: "15 yrs exp." },
        { name: "Michael Chen", role: "Business Accountant", years: "10 yrs exp." },
        { name: "Priya Patel", role: "Payroll Specialist", years: "8 yrs exp." },
      ].map((member) => (
        <div class="text-center group">
          <div class="overflow-hidden rounded-2xl mb-4 shadow-sm">
            <img
              src="/images/placeholder.jpg"
              alt={member.name}
              class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <h3 class="text-gray-800 font-semibold text-lg">{member.name}</h3>
          <p class="text-blue-600 text-sm font-medium">{member.role}</p>
          <p class="text-gray-400 text-xs mt-1">{member.years}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why Choose Us -->
  <section id="why-us" class="py-20 px-6 bg-blue-900 text-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-blue-300 uppercase tracking-widest text-sm font-semibold mb-2">
          Why J&amp;S Tax?
        </p>
        <h2 class="text-3xl font-bold mb-5">
          The Difference a Dedicated Team Makes
        </h2>
        <p class="text-blue-100 leading-relaxed mb-8">
          With countless accounting firms to choose from, we understand you have
          options. Here's why hundreds of clients return to us year after year —
          and refer their friends and family.
        </p>
        <ul class="space-y-4">
          {[
            "Certified CPAs and enrolled agents on staff",
            "Year-round support — not just during tax season",
            "Fixed, transparent pricing with no surprise fees",
            "Convenient online document submission portal",
            "IRS representation in the event of an audit",
            "Bilingual staff available for Spanish-speaking clients",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-blue-500 flex items-center justify-center text-xs font-bold">
                ✓
              </span>
              <span class="text-blue-100 text-sm">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-xl">
        <img
          src="/images/placeholder.jpg"
          alt="Accountants at work"
          class="w-full h-96 object-cover"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact-cta" class="py-20 px-6 bg-gray-50 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="text-blue-600 uppercase tracking-widest text-sm font-semibold mb-2">
        Ready to Get Started?
      </p>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">
        Let's Talk About Your Tax &amp; Accounting Needs
      </h2>
      <p class="text-gray-500 leading-relaxed mb-8">
        Whether you need help with personal taxes, business accounting, or
        payroll, our team is here to simplify the process and maximize your
        results. Schedule a free consultation today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact-us"
          class="inline-block bg-blue-700 hover:bg-blue-800 text-white font-semibold py-3 px-8 rounded-full transition-colors"
        >
          Schedule a Free Consultation
        </a>
        <a
          href="tel:+15551234567"
          class="inline-block border-2 border-blue-700 text-blue-700 hover:bg-blue-700 hover:text-white font-semibold py-3 px-8 rounded-full transition-colors"
        >
          Call (555) 123-4567
        </a>
      </div>
    </div>
  </section>
</Base>