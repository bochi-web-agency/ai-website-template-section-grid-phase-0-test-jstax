---
import Base from "../layouts/Base.astro";

const teamMembers = [
  {
    name: "John Smith",
    title: "CPA, Managing Partner",
    bio: "John has over 20 years of experience in tax planning and accounting services for individuals and small businesses. He founded J&S Tax Accountants with a mission to provide personalized, reliable financial guidance.",
    image: "/images/placeholder.jpg",
  },
  {
    name: "Sarah Johnson",
    title: "CPA, Senior Tax Advisor",
    bio: "Sarah specializes in corporate tax strategy and IRS representation. She brings 15 years of experience helping clients navigate complex tax situations with confidence and clarity.",
    image: "/images/placeholder.jpg",
  },
  {
    name: "Michael Torres",
    title: "Enrolled Agent, Tax Specialist",
    bio: "Michael is an IRS Enrolled Agent focused on small business accounting, payroll services, and bookkeeping. His proactive approach ensures clients stay compliant and financially prepared year-round.",
    image: "/images/placeholder.jpg",
  },
];

const values = [
  {
    icon: "🤝",
    title: "Client-First Approach",
    description:
      "We listen carefully to each client's unique situation and tailor our services to meet their specific financial goals.",
  },
  {
    icon: "🔍",
    title: "Accuracy & Integrity",
    description:
      "We uphold the highest standards of professional ethics, ensuring every return and report is accurate and compliant.",
  },
  {
    icon: "📈",
    title: "Proactive Planning",
    description:
      "We don't just react to tax season — we help clients plan year-round to minimize liabilities and maximize opportunities.",
  },
  {
    icon: "💬",
    title: "Clear Communication",
    description:
      "We translate complex tax and financial concepts into plain language so you always understand your financial picture.",
  },
];

const stats = [
  { number: "20+", label: "Years of Experience" },
  { number: "1,500+", label: "Clients Served" },
  { number: "98%", label: "Client Retention Rate" },
  { number: "3", label: "Certified Professionals" },
];
---

<Base title="About Us | J&S Tax Accountants">
  <!-- Hero / Page Banner -->
  <section
    id="about-hero"
    class="relative bg-blue-900 text-white py-24 px-6 overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-cover bg-center opacity-20"
      style="background-image: url('/images/placeholder.jpg');"
    ></div>
    <div class="relative max-w-5xl mx-auto text-center">
      <p
        class="uppercase tracking-widest text-blue-300 text-sm font-semibold mb-3"
      >
        Who We Are
      </p>
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
        About J&amp;S Tax Accountants
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        We are a dedicated team of certified tax professionals committed to
        helping individuals and businesses achieve financial clarity, compliance,
        and long-term prosperity.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section id="our-story" class="py-20 px-6 bg-white">
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-14 items-center"
    >
      <div>
        <img
          src="/images/placeholder.jpg"
          alt="Our office"
          class="rounded-2xl shadow-xl w-full h-80 object-cover"
        />
      </div>
      <div>
        <p
          class="uppercase tracking-widest text-blue-600 text-sm font-semibold mb-3"
        >
          Our Story
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-snug">
          Built on Trust, Driven by Results
        </h2>
        <p class="text-gray-600 text-base leading-relaxed mb-4">
          J&amp;S Tax Accountants was founded over two decades ago with a simple
          but powerful idea: every client deserves the same level of expert
          financial guidance that Fortune 500 companies receive. We started as a
          small family-run practice and have grown into a trusted community
          resource for tax preparation, planning, and accounting services.
        </p>
        <p class="text-gray-600 text-base leading-relaxed mb-6">
          From sole proprietors to multi-entity businesses, our team has handled
          thousands of tax situations with precision and care. We pride ourselves
          on building long-term relationships — many of our clients have been
          with us for 10 years or more.
        </p>
        <a
          href="/contact-us"
          class="inline-block bg-blue-700 text-white font-semibold px-7 py-3 rounded-full hover:bg-blue-800 transition-colors duration-200"
        >
          Get In Touch
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section id="stats" class="bg-blue-700 py-14 px-6">
    <div
      class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white"
    >
      {
        stats.map((stat) => (
          <div>
            <div class="text-5xl font-extrabold mb-2">{stat.number}</div>
            <div class="text-blue-200 text-sm uppercase tracking-wide font-medium">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Our Values -->
  <section id="our-values" class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p
          class="uppercase tracking-widest text-blue-600 text-sm font-semibold mb-3"
        >
          What We Stand For
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Our Core Values
        </h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">
          These principles guide everything we do — from how we serve clients to
          how we operate as a team.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          values.map((value) => (
            <div class="bg-white rounded-2xl shadow-md p-8 text-center hover:shadow-lg transition-shadow duration-200">
              <div class="text-5xl mb-4">{value.icon}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-3">
                {value.title}
              </h3>
              <p class="text-gray-500 text-sm leading-relaxed">
                {value.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Meet the Team -->
  <section id="meet-the-team" class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p
          class="uppercase tracking-widest text-blue-600 text-sm font-semibold mb-3"
        >
          The People Behind the Numbers
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Meet Our Team
        </h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">
          Our certified professionals bring decades of combined experience to
          every client engagement.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {
          teamMembers.map((member) => (
            <div class="group bg-gray-50 rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
              <div class="overflow-hidden">
                <img
                  src={member.image}
                  alt={member.name}
                  class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-1">
                  {member.name}
                </h3>
                <p class="text-blue-600 text-sm font-semibold mb-3">
                  {member.title}
                </p>
                <p class="text-gray-500 text-sm leading-relaxed">{member.bio}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section id="why-choose-us" class="py-20 px-6 bg-blue-900 text-white">
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-14 items-center"
    >
      <div>
        <p
          class="uppercase tracking-widest text-blue-300 text-sm font-semibold mb-3"
        >
          Why J&amp;S Tax?
        </p>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-snug">
          The Right Choice for Your Tax &amp; Accounting Needs
        </h2>
        <ul class="space-y-4 text-blue-100 text-base">
          <li class="flex items-start gap-3">
            <span class="text-green-400 mt-1 text-lg">✓</span>
            <span
              >Licensed CPAs and Enrolled Agents with specialized expertise
              across all tax situations.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-400 mt-1 text-lg">✓</span>
            <span
              >Year-round availability — not just during tax season — so you
              always have expert support.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-400 mt-1 text-lg">✓</span>
            <span
              >Personalized strategies tailored to your unique financial
              situation and goals.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-400 mt-1 text-lg">✓</span>
            <span
              >Transparent pricing with no hidden fees — you always know what
              you're paying for.</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-green-400 mt-1 text-lg">✓</span>
            <span
              >IRS representation and audit support to protect you when it
              matters most.</span
            >
          </li>
        </ul>
      </div>
      <div class="relative">
        <img
          src="/images/placeholder.jpg"
          alt="Tax professionals at work"
          class="rounded-2xl shadow-2xl w-full h-96 object-cover"
        />
        <div
          class="absolute -bottom-6 -left-6 bg-blue-600 text-white rounded-2xl p-6 shadow-xl max-w-xs"
        >
          <p class="text-3xl font-extrabold">98%</p>
          <p class="text-blue-200 text-sm mt-1">
            of our clients return to us year after year
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta" class="py-20 px-6 bg-gray-50 text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-5">
        Ready to Work with a Team You Can Trust?
      </h2>
      <p class="text-gray-500 text-lg mb-8">
        Schedule your free consultation today and discover how J&amp;S Tax
        Accountants can simplify your finances and help you keep more of what
        you earn.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact-us"
          class="inline-block bg-blue-700 text-white font-semibold px-8 py-4 rounded-full hover:bg-blue-800 transition-colors duration-200 text-lg"
        >
          Schedule a Free Consultation
        </a>
        <a
          href="/services"
          class="inline-block border-2 border-blue-700 text-blue-700 font-semibold px-8 py-4 rounded-full hover:bg-blue-50 transition-colors duration-200 text-lg"
        >
          View Our Services
        </a>
      </div>
    </div>
  </section>
</Base>