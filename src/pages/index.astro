---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "index");
const { title, description, meta_title, meta_image, hero_title, hero_content, hero_cta } = entry.data;
---

<Base title={meta_title || title} description={description}>

  <!-- Hero Section -->
  <section id="hero" class="relative bg-blue-900 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/placeholder.jpg"
        alt="Hero background"
        class="w-full h-full object-cover opacity-20"
      />
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-28 flex flex-col items-center text-center gap-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
        {hero_title}
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-2xl">
        {hero_content}
      </p>
      {hero_cta && (
        <a
          href={hero_cta.url}
          class="mt-4 inline-block bg-yellow-400 text-blue-900 font-semibold px-8 py-4 rounded-lg text-lg hover:bg-yellow-300 transition-colors duration-200 shadow-lg"
        >
          {hero_cta.label}
        </a>
      )}
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-blue-800 text-white py-5">
    <div class="max-w-6xl mx-auto px-6 flex flex-wrap justify-center gap-8 text-sm font-medium tracking-wide">
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.122-6.545L.488 6.91l6.562-.954L10 0l2.95 5.956 6.562.954-4.756 4.635 1.122 6.545z"/></svg>
        CPA Certified Professionals
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.122-6.545L.488 6.91l6.562-.954L10 0l2.95 5.956 6.562.954-4.756 4.635 1.122 6.545z"/></svg>
        20+ Years of Experience
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.122-6.545L.488 6.91l6.562-.954L10 0l2.95 5.956 6.562.954-4.756 4.635 1.122 6.545z"/></svg>
        500+ Happy Clients
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.122-6.545L.488 6.91l6.562-.954L10 0l2.95 5.956 6.562.954-4.756 4.635 1.122 6.545z"/></svg>
        Personalized Tax Solutions
      </span>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="bg-gray-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-blue-700 font-semibold uppercase tracking-widest text-sm mb-2">What We Offer</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Our Tax & Accounting Services</h2>
        <p class="mt-4 text-gray-500 max-w-2xl mx-auto text-lg">
          From individual tax returns to full-service business accounting, we've got you covered year-round.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            icon: "📋",
            title: "Personal Tax Returns",
            desc: "Accurate, maximized individual tax filings handled by our experienced CPAs. We find every deduction you're entitled to."
          },
          {
            icon: "🏢",
            title: "Business Tax Services",
            desc: "Corporate, partnership, and LLC tax filings done right. We ensure compliance and strategic planning for your business."
          },
          {
            icon: "📊",
            title: "Bookkeeping & Accounting",
            desc: "Stay on top of your finances with monthly or quarterly bookkeeping, reconciliation, and financial reporting."
          },
          {
            icon: "💼",
            title: "Payroll Services",
            desc: "Timely and accurate payroll processing, tax remittances, and T4 preparation for businesses of all sizes."
          },
          {
            icon: "🛡️",
            title: "CRA Audit Support",
            desc: "Facing a CRA audit? We represent you, organize documentation, and communicate with the agency on your behalf."
          },
          {
            icon: "📈",
            title: "Tax Planning & Strategy",
            desc: "Proactive year-round tax planning to minimize your liability and keep more money in your pocket."
          }
        ].map(service => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-md transition-shadow duration-200 flex flex-col gap-4">
            <div class="text-4xl">{service.icon}</div>
            <h3 class="text-xl font-bold text-gray-900">{service.title}</h3>
            <p class="text-gray-500 leading-relaxed">{service.desc}</p>
            <a href="/services" class="mt-auto text-blue-700 font-semibold hover:text-blue-900 transition-colors text-sm inline-flex items-center gap-1">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About / Why Choose Us Section -->
  <section id="about" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/images/placeholder.jpg"
          alt="J&S Tax Accountants team"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="flex flex-col gap-6">
        <p class="text-blue-700 font-semibold uppercase tracking-widest text-sm">About J&S Tax</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight">
          Trusted Accountants Who Put Clients First
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed">
          J&S Tax Accountants has been serving individuals and small businesses with professional, personalized tax and accounting services for over 20 years. Our team of certified professionals understands the complexities of Canadian tax law and works diligently to protect and grow your financial wellbeing.
        </p>
        <p class="text-gray-500 leading-relaxed">
          We believe every client deserves dedicated attention. Whether you're filing your first return or managing a growing enterprise, we tailor our approach to your unique needs.
        </p>
        <ul class="flex flex-col gap-3 mt-2">
          {[
            "CPA-certified team members",
            "Transparent, flat-rate pricing",
            "Year-round support — not just tax season",
            "Available in-person, by phone, or online"
          ].map(item => (
            <li class="flex items-center gap-3 text-gray-700">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-sm font-bold">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-4">
          <a href="/about-us" class="inline-block bg-blue-800 text-white font-semibold px-7 py-3 rounded-lg hover:bg-blue-700 transition-colors duration-200">
            Learn About Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-blue-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {[
        { stat: "20+", label: "Years of Experience" },
        { stat: "500+", label: "Happy Clients" },
        { stat: "98%", label: "Client Retention Rate" },
        { stat: "$2M+", label: "Tax Savings for Clients" }
      ].map(item => (
        <div class="flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-bold text-yellow-400">{item.stat}</span>
          <span class="text-blue-200 text-sm font-medium">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-blue-700 font-semibold uppercase tracking-widest text-sm mb-2">Client Reviews</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">What Our Clients Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            name: "Sarah M.",
            role: "Small Business Owner",
            quote: "J&S Tax has been handling our corporate taxes for five years. They're thorough, responsive, and always find savings we would have missed. Highly recommend!"
          },
          {
            name: "David K.",
            role: "Freelance Consultant",
            quote: "I was nervous about my first self-employment return. The team walked me through everything, kept it stress-free, and got me a bigger refund than I expected."
          },
          {
            name: "Linda & Tom R.",
            role: "Homeowners",
            quote: "We've used J&S Tax for years. They're trustworthy, affordable, and truly care about their clients. We wouldn't go anywhere else for our tax needs."
          }
        ].map(t => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex flex-col gap-5">
            <div class="flex gap-1">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.122-6.545L.488 6.91l6.562-.954L10 0l2.95 5.956 6.562.954-4.756 4.635 1.122 6.545z"/></svg>
              ))}
            </div>
            <p class="text-gray-600 leading-relaxed italic">"{t.quote}"</p>
            <div class="mt-auto flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-800 font-bold text-sm flex-shrink-0">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="font-bold text-gray-900 text-sm">{t.name}</p>
                <p class="text-gray-400 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-blue-700 font-semibold uppercase tracking-widest text-sm mb-2">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Simple, Stress-Free Process</h2>
        <p class="mt-4 text-gray-500 max-w-xl mx-auto">
          Getting your taxes done shouldn't be complicated. Here's how we make it easy.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: "01", title: "Book a Consultation", desc: "Schedule a free initial consultation — in person, by phone, or online." },
          { step: "02", title: "Submit Your Documents", desc: "Securely send or drop off your tax documents and financial records." },
          { step: "03", title: "We Prepare & Review", desc: "Our team prepares your return and reviews it thoroughly for accuracy and maximum savings." },
          { step: "04", title: "File & Relax", desc: "We file electronically and keep you updated. You get your refund fast." }
        ].map(p => (
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-16 h-16 rounded-full bg-blue-900 text-white text-xl font-bold flex items-center justify-center shadow-md">
              {p.step}
            </div>
            <h3 class="text-lg font-bold text-gray-900">{p.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact / CTA Section -->
  <section id="contact" class="py-20 bg-blue-900 text-white">
    <div class="max-w-4xl mx-auto px-6 text-center flex flex-col items-center gap-8">
      <h2 class="text-3xl md:text-4xl font-bold leading-tight">
        Ready to Take Control of Your Taxes?
      </h2>
      <p class="text-blue-200 text-lg max-w-xl">
        Contact J&S Tax Accountants today and let our experienced team handle the numbers so you can focus on what matters most.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/contact-us"
          class="bg-yellow-400 text-blue-900 font-bold px-8 py-4 rounded-lg text-lg hover:bg-yellow-300 transition-colors duration-200 shadow-lg"
        >
          Schedule a Free Consultation
        </a>
        <a
          href="tel:+16045551234"
          class="border-2 border-white text-white font-bold px-8 py-4 rounded-lg text-lg hover:bg-white hover:text-blue-900 transition-colors duration-200"
        >
          Call Us Today
        </a>
      </div>
      <div class="mt-4 flex flex-col sm:flex-row gap-6 text-blue-200 text-sm">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (604) 555-1234
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          info@jstaxaccountants.com
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Vancouver, BC
        </span>
      </div>
    </div>
  </section>

</Base>