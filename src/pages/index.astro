---
import Base from "../layouts/Base.astro";
---

<Base title="Section Grid Phase 0 Test JSTax | Tax Accountants">
  <!-- Navigation -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-bold text-blue-900">J&amp;S<span class="text-amber-500">Tax</span></span>
        <span class="text-sm text-gray-500 hidden sm:inline">Accountants</span>
      </a>
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="text-blue-900 font-semibold border-b-2 border-amber-500 pb-0.5">Home</a>
        <a href="#services" class="text-gray-600 hover:text-blue-900 transition-colors">Services</a>
        <a href="#about" class="text-gray-600 hover:text-blue-900 transition-colors">About Us</a>
        <a href="#contact" class="text-gray-600 hover:text-blue-900 transition-colors">Contact Us</a>
      </nav>
      <a href="#contact" class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-5 py-2 rounded transition-colors text-sm">
        Get a Free Consultation
      </a>
    </div>
  </header>

  <!-- Hero Section -->
  <section id="hero" class="relative bg-blue-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-gradient-to-br from-blue-700 to-blue-950"></div>
    <div class="absolute right-0 top-0 w-1/2 h-full hidden lg:block">
      <img src="/images/placeholder.jpg" alt="Tax professionals" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 lg:py-36">
      <div class="max-w-xl">
        <span class="inline-block bg-amber-500 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Trusted Tax Professionals
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Expert Tax &amp; Accounting Solutions
        </h1>
        <p class="text-blue-100 text-lg mb-8 leading-relaxed">
          J&amp;S Tax Accountants delivers personalized financial services to individuals, families, and small businesses. Let us handle the numbers so you can focus on what matters most.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-8 py-3 rounded-lg transition-colors shadow-lg">
            Book a Consultation
          </a>
          <a href="#services" class="border-2 border-white text-white hover:bg-white hover:text-blue-900 font-bold px-8 py-3 rounded-lg transition-colors">
            Our Services
          </a>
        </div>
      </div>
    </div>
    <!-- Stats Bar -->
    <div class="relative bg-blue-800 border-t border-blue-700">
      <div class="max-w-6xl mx-auto px-4 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl font-extrabold text-amber-400">15+</p>
          <p class="text-blue-200 text-sm mt-1">Years Experience</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-amber-400">1,200+</p>
          <p class="text-blue-200 text-sm mt-1">Clients Served</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-amber-400">98%</p>
          <p class="text-blue-200 text-sm mt-1">Satisfaction Rate</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-amber-400">$2M+</p>
          <p class="text-blue-200 text-sm mt-1">Tax Savings Found</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-semibold uppercase tracking-widest text-sm">What We Offer</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mt-2 mb-4">Our Professional Services</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Comprehensive accounting and tax solutions tailored to your unique financial needs — from simple returns to complex business filings.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            icon: "📋",
            title: "Personal Tax Returns",
            desc: "Accurate and timely preparation of individual tax returns, maximizing your refund and ensuring full compliance.",
          },
          {
            icon: "🏢",
            title: "Business Tax Filing",
            desc: "End-to-end tax filing for sole proprietors, partnerships, LLCs, and corporations of all sizes.",
          },
          {
            icon: "📊",
            title: "Bookkeeping & Accounting",
            desc: "Monthly and annual bookkeeping services to keep your finances organized and audit-ready year-round.",
          },
          {
            icon: "💼",
            title: "Payroll Services",
            desc: "Streamlined payroll processing and compliance so your team gets paid accurately and on time.",
          },
          {
            icon: "🔍",
            title: "IRS Audit Representation",
            desc: "Expert representation and guidance if you receive an IRS notice or face an audit situation.",
          },
          {
            icon: "📈",
            title: "Financial Planning",
            desc: "Strategic financial planning and advisory services to help you build long-term wealth and stability.",
          },
        ].map((service) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow p-8 border border-gray-100 group">
            <div class="text-4xl mb-4">{service.icon}</div>
            <h3 class="text-xl font-bold text-blue-900 mb-3 group-hover:text-amber-500 transition-colors">{service.title}</h3>
            <p class="text-gray-500 leading-relaxed text-sm">{service.desc}</p>
            <a href="#contact" class="inline-block mt-5 text-amber-500 font-semibold text-sm hover:underline">
              Learn More →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img src="/images/placeholder.jpg" alt="About J&S Tax Accountants" class="rounded-2xl w-full object-cover h-96 shadow-lg" />
        <div class="absolute -bottom-6 -right-6 bg-amber-500 text-white rounded-2xl p-6 shadow-xl hidden md:block">
          <p class="text-4xl font-extrabold">15+</p>
          <p class="text-sm font-medium mt-1">Years of Trusted<br />Tax Expertise</p>
        </div>
      </div>
      <div>
        <span class="text-amber-500 font-semibold uppercase tracking-widest text-sm">About Us</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mt-2 mb-6">
          Your Trusted Local Tax &amp; Accounting Partner
        </h2>
        <p class="text-gray-500 leading-relaxed mb-4">
          At J&amp;S Tax Accountants, we believe that everyone deserves access to expert financial guidance. Founded over 15 years ago, our firm has been serving individuals and businesses in the community with honesty, integrity, and a commitment to excellence.
        </p>
        <p class="text-gray-500 leading-relaxed mb-8">
          Our team of certified tax professionals stays current with the latest tax laws and regulations so you never miss a deduction or credit. We take the stress out of tax season and provide year-round support to help you achieve your financial goals.
        </p>
        <ul class="space-y-3 mb-8">
          {[
            "Certified Public Accountants (CPA) on staff",
            "Transparent, flat-fee pricing — no surprises",
            "Personalized service for every client",
            "Secure, confidential document handling",
          ].map((item) => (
            <li class="flex items-start gap-3 text-gray-700">
              <span class="text-amber-500 mt-0.5 text-lg">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href="#contact" class="inline-block bg-blue-900 hover:bg-blue-800 text-white font-bold px-8 py-3 rounded-lg transition-colors">
          Meet Our Team
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="py-20 bg-blue-900 text-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-amber-400 font-semibold uppercase tracking-widest text-sm">Client Reviews</span>
        <h2 class="text-3xl md:text-4xl font-extrabold mt-2 mb-4">What Our Clients Say</h2>
        <p class="text-blue-200 max-w-xl mx-auto">
          We're proud of the relationships we've built with our clients. Here's what some of them have to say about working with J&amp;S Tax Accountants.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            name: "Maria T.",
            role: "Small Business Owner",
            quote: "J&S Tax has been handling our business taxes for over 7 years. They're responsive, thorough, and always find deductions we didn't know existed. Couldn't recommend them more highly!",
            rating: 5,
          },
          {
            name: "David K.",
            role: "Freelance Consultant",
            quote: "As a self-employed contractor, my taxes can be complicated. The team at J&S made everything straightforward and saved me a significant amount this year. Fantastic service!",
            rating: 5,
          },
          {
            name: "Sandra L.",
            role: "Homeowner & Parent",
            quote: "Switching to J&S Tax was the best financial decision I made. They explained everything clearly and I felt confident knowing my return was in expert hands. Truly professional!",
            rating: 5,
          },
        ].map((t) => (
          <div class="bg-blue-800 rounded-2xl p-8 border border-blue-700">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <span class="text-amber-400 text-lg">★</span>
              ))}
            </div>
            <p class="text-blue-100 leading-relaxed mb-6 italic">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber-500 flex items-center justify-center font-bold text-white">
                {t.name[0]}
              </div>
              <div>
                <p class="font-semibold text-white">{t.name}</p>
                <p class="text-blue-300 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us / Process -->
  <section id="process" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-semibold uppercase tracking-widest text-sm">How It Works</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mt-2 mb-4">Getting Started Is Simple</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Our streamlined process ensures a stress-free experience from your first consultation to your completed return.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        {[
          { step: "01", title: "Schedule a Consultation", desc: "Book a free initial meeting online, by phone, or in person at our office." },
          { step: "02", title: "Share Your Documents", desc: "Securely upload or drop off your financial documents for our review." },
          { step: "03", title: "We Prepare Your Return", desc: "Our experts prepare your return, maximizing every deduction and credit." },
          { step: "04", title: "Review & File", desc: "We walk you through the results and e-file once you're fully satisfied." },
        ].map((s, i) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative">
            <div class="w-14 h-14 bg-amber-500 text-white rounded-full flex items-center justify-center font-extrabold text-xl mx-auto mb-4">
              {s.step}
            </div>
            <h3 class="font-bold text-blue-900 text-lg mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <span class="text-amber-500 font-semibold uppercase tracking-widest text-sm">Contact Us</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mt-2 mb-4">Ready to Get Started?</h2>
        <p class="text-gray-500 leading-relaxed mb-8">
          Contact our team today to schedule your free consultation. We're here to answer your questions and help you navigate every aspect of your taxes and accounting needs.
        </p>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-900 text-xl shrink-0">📍</div>
            <div>
              <p class="font-bold text-blue-900">Our Office</p>
              <p class="text-gray-500 text-sm mt-1">123 Main Street, Suite 400<br />Your City, State 00000</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-900 text-xl shrink-0">📞</div>
            <div>
              <p class="font-bold text-blue-900">Phone</p>
              <p class="text-gray-500 text-sm mt-1">(555) 123-4567</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-900 text-xl shrink-0">✉️</div>
            <div>
              <p class="font-bold text-blue-900">Email</p>
              <p class="text-gray-500 text-sm mt-1">info@jstaxaccountants.com</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-900 text-xl shrink-0">🕐</div>
            <div>
              <p class="font-bold text-blue-900">Office Hours</p>
              <p class="text-gray-500 text-sm mt-1">Mon – Fri: 9:00 AM – 6:00 PM<br />Sat: 10:00 AM – 3:00 PM</p>
            </div>
          </div>
        </div>
      </div>
      <!-- Contact Form -->
      <div class="bg-blue-900 rounded-2xl p-10 text-white shadow-xl">
        <h3 class="text-2xl font-bold mb-6">Send Us a Message</h3>
        <form class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="text-blue-200 text-sm mb-1 block">First Name</label>
              <input type="text" placeholder="John" class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white placeholder-blue-400 focus:outline-none focus:border-amber-400 transition-colors" />
            </div>
            <div>
              <label class="text-blue-200 text-sm mb-1 block">Last Name</label>
              <input type="text" placeholder="Smith" class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white placeholder-blue-400 focus:outline-none focus:border-amber-400 transition-colors" />
            </div>
          </div>
          <div>
            <label class="text-blue-200 text-sm mb-1 block">Email Address</label>
            <input type="email" placeholder="john@example.com" class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white placeholder-blue-400 focus:outline-none focus:border-amber-400 transition-colors" />
          </div>
          <div>
            <label class="text-blue-200 text-sm mb-1 block">Phone Number</label>
            <input type="tel" placeholder="(555) 000-0000" class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white placeholder-blue-400 focus:outline-none focus:border-amber-400 transition-colors" />
          </div>
          <div>
            <label class="text-blue-200 text-sm mb-1 block">Service Needed</label>
            <select class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-amber-400 transition-colors">
              <option value="">Select a service…</option>
              <option>Personal Tax Return</option>
              <option>Business Tax Filing</option>
              <option>Bookkeeping & Accounting</option>
              <option>Payroll Services</option>
              <option>IRS Audit Representation</option>
              <option>Financial Planning</option>
            </select>
          </div>
          <div>
            <label class="text-blue-200 text-sm mb-1 block">Message</label>
            <textarea rows="4" placeholder="Tell us more about your needs…" class="w-full bg-blue-800 border border-blue-700 rounded-lg px-4 py-3 text-white placeholder-blue-400 focus:outline-none focus:border-amber-400 transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 rounded-lg transition-colors text-lg shadow-md">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-blue-950 text-blue-200 py-12">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <p class="text-2xl font-extrabold text-white mb-3">J&amp;S<span class="text-amber-400">Tax</span> Accountants</p>
        <p class="text-sm leading-relaxed text-blue-300 max-w-xs">
          Trusted tax and accounting professionals dedicated to helping individuals and businesses achieve financial clarity and peace of mind.
        </p>
      </div>
      <div>
        <p class="font-bold text-white mb-4">Quick Links</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-amber-400 transition-colors">Home</a></li>
          <li><a href="#services" class="hover:text-amber-400 transition-colors">Services</a></li>
          <li><a href="#about" class="hover:text-amber-400 transition-colors">About Us</a></li>
          <li><a href="#contact" class="hover:text-amber-400 transition-colors">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <p class="font-bold text-white mb-4">Services</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#services" class="hover:text-amber-400 transition-colors">Personal Tax Returns</a></li>
          <li><a href="#services" class="hover:text-amber-400 transition-colors">Business Tax Filing</a></li>
          <li><a href="#services" class="hover:text-amber-400 transition-colors">Bookkeeping</a></li>
          <li><a href="#services" class="hover:text-amber-400 transition-colors">Payroll Services</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto px-4 mt-10 pt-6 border-t border-blue-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-blue-400">
      <p>© {new Date().getFullYear()} J&S Tax Accountants. All rights reserved.</p>
      <p>Designed for local tax professionals.</p>
    </div>
  </footer>
</Base>