---
import Base from "../layouts/Base.astro";

const services = [
  {
    icon: "📊",
    title: "Tax Preparation",
    description:
      "Accurate and timely personal and business tax preparation services tailored to your financial situation.",
  },
  {
    icon: "📁",
    title: "Bookkeeping",
    description:
      "Comprehensive bookkeeping solutions to keep your financial records organized and up to date.",
  },
  {
    icon: "💼",
    title: "Business Accounting",
    description:
      "Full-service accounting support for small and medium-sized businesses, from payroll to financial reporting.",
  },
  {
    icon: "🏦",
    title: "Tax Planning",
    description:
      "Strategic tax planning to minimize liabilities and maximize savings for individuals and businesses.",
  },
  {
    icon: "📝",
    title: "IRS Representation",
    description:
      "Professional representation and support when dealing with IRS audits, notices, and disputes.",
  },
  {
    icon: "📈",
    title: "Financial Consulting",
    description:
      "Expert financial guidance to help you make informed decisions and achieve your financial goals.",
  },
];

const testimonials = [
  {
    name: "Maria Gonzalez",
    role: "Small Business Owner",
    text: "J&S Tax Accountants have been handling our business taxes for three years. They are professional, thorough, and always responsive. I couldn't ask for better service!",
    initials: "MG",
  },
  {
    name: "David Thompson",
    role: "Freelance Consultant",
    text: "Switching to J&S Tax was the best financial decision I made. They saved me thousands in taxes and made the entire process stress-free.",
    initials: "DT",
  },
  {
    name: "Sandra Lee",
    role: "Retail Store Owner",
    text: "Their bookkeeping service keeps my business running smoothly. I always know exactly where my finances stand. Highly recommend!",
    initials: "SL",
  },
];

const stats = [
  { value: "15+", label: "Years of Experience" },
  { value: "500+", label: "Happy Clients" },
  { value: "98%", label: "Client Retention Rate" },
  { value: "$2M+", label: "Tax Savings Delivered" },
];
---

<Base title="J&S Tax Accountants – Professional Tax & Accounting Services">
  <!-- NAV -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-extrabold text-blue-800 tracking-tight">J&amp;S Tax</span>
        <span class="text-sm font-semibold text-gray-500 hidden sm:inline">Accountants</span>
      </a>
      <nav class="hidden md:flex gap-8 text-sm font-semibold text-gray-700">
        <a href="#hero" class="hover:text-blue-700 transition-colors">Home</a>
        <a href="#services" class="hover:text-blue-700 transition-colors">Services</a>
        <a href="#about" class="hover:text-blue-700 transition-colors">About Us</a>
        <a href="#contact" class="hover:text-blue-700 transition-colors">Contact Us</a>
      </nav>
      <a
        href="#contact"
        class="hidden md:inline-block bg-blue-700 hover:bg-blue-800 text-white text-sm font-semibold px-5 py-2.5 rounded-md transition-colors"
      >
        Get a Free Quote
      </a>
      <button class="md:hidden p-2 rounded text-gray-700 hover:bg-gray-100" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section id="hero" class="relative bg-blue-900 text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/placeholder.jpg"
        alt="Office background"
        class="w-full h-full object-cover opacity-20"
      />
    </div>
    <div class="relative max-w-6xl mx-auto px-4 py-28 md:py-36 flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1 text-center md:text-left">
        <span class="inline-block bg-blue-600 text-blue-100 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4">
          Trusted Accounting Professionals
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
          Expert Tax &amp; Accounting <span class="text-yellow-400">Services You Can Trust</span>
        </h1>
        <p class="text-lg md:text-xl text-blue-100 mb-8 max-w-xl">
          J&amp;S Tax Accountants provides personalized, reliable tax preparation, bookkeeping, and financial consulting for individuals and businesses.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a
            href="#contact"
            class="bg-yellow-400 hover:bg-yellow-300 text-blue-900 font-bold px-8 py-4 rounded-lg text-base transition-colors shadow-lg"
          >
            Schedule a Consultation
          </a>
          <a
            href="#services"
            class="border-2 border-white hover:bg-white hover:text-blue-900 text-white font-bold px-8 py-4 rounded-lg text-base transition-colors"
          >
            Our Services
          </a>
        </div>
      </div>
      <div class="flex-1 flex justify-center md:justify-end">
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-8 max-w-sm w-full">
          <h2 class="text-xl font-bold mb-4 text-yellow-300">Free Tax Consultation</h2>
          <form class="flex flex-col gap-3">
            <input
              type="text"
              placeholder="Your Full Name"
              class="bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-blue-200 text-sm focus:outline-none focus:border-yellow-400 transition-colors"
            />
            <input
              type="email"
              placeholder="Email Address"
              class="bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-blue-200 text-sm focus:outline-none focus:border-yellow-400 transition-colors"
            />
            <input
              type="tel"
              placeholder="Phone Number"
              class="bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white placeholder-blue-200 text-sm focus:outline-none focus:border-yellow-400 transition-colors"
            />
            <button
              type="submit"
              class="bg-yellow-400 hover:bg-yellow-300 text-blue-900 font-bold py-3 rounded-lg text-sm transition-colors mt-1"
            >
              Request Free Consultation
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BANNER -->
  <section class="bg-blue-700 text-white py-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div class="flex flex-col items-center">
            <span class="text-4xl font-extrabold text-yellow-300">{stat.value}</span>
            <span class="text-sm text-blue-100 mt-1 font-medium">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-blue-700 text-sm font-bold uppercase tracking-widest">What We Offer</span>
        <h2 class="text-4xl font-extrabold text-gray-900 mt-2 mb-4">Our Accounting &amp; Tax Services</h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg">
          We offer a full range of financial services designed to help you navigate taxes and grow your business with confidence.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg border border-gray-100 p-8 flex flex-col gap-4 transition-shadow group">
            <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-3xl group-hover:bg-blue-100 transition-colors">
              {service.icon}
            </div>
            <h3 class="text-xl font-bold text-gray-900">{service.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{service.description}</p>
            <a href="#contact" class="text-blue-700 text-sm font-semibold hover:underline mt-auto inline-flex items-center gap-1">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-14">
        <div class="flex-1">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img
              src="/images/placeholder.jpg"
              alt="Our team at J&S Tax Accountants"
              class="w-full h-80 object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-blue-900/80 to-transparent p-6">
              <p class="text-white font-bold text-lg">Your Trusted Financial Partners</p>
              <p class="text-blue-200 text-sm">Serving the community for over 15 years</p>
            </div>
          </div>
        </div>
        <div class="flex-1">
          <span class="text-blue-700 text-sm font-bold uppercase tracking-widest">About J&amp;S Tax</span>
          <h2 class="text-4xl font-extrabold text-gray-900 mt-2 mb-6 leading-tight">
            Dedicated Professionals <br />Here to Serve You
          </h2>
          <p class="text-gray-600 mb-4 leading-relaxed">
            At J&amp;S Tax Accountants, we believe that every client deserves personalized attention and expert financial guidance. With over 15 years of experience serving individuals and businesses, our team is committed to delivering accurate, timely, and strategic accounting solutions.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Whether you need help filing your annual taxes, managing your business books, or planning for the future, we are here to make the process simple and stress-free. Our certified professionals stay up to date with the latest tax laws to ensure you always get the best outcome.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 bg-yellow-400 rounded-full flex items-center justify-center text-blue-900 font-bold text-sm flex-shrink-0">✓</span>
              <span class="text-gray-700 text-sm font-medium">IRS Enrolled Agents &amp; CPAs on staff</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 bg-yellow-400 rounded-full flex items-center justify-center text-blue-900 font-bold text-sm flex-shrink-0">✓</span>
              <span class="text-gray-700 text-sm font-medium">Year-round support, not just tax season</span>
            </div>
          </div>
          <a
            href="#contact"
            class="inline-block mt-8 bg-blue-700 hover:bg-blue-800 text-white font-bold px-8 py-4 rounded-lg transition-colors"
          >
            Meet Our Team
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-20 bg-blue-900 text-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-yellow-400 text-sm font-bold uppercase tracking-widest">Client Reviews</span>
        <h2 class="text-4xl font-extrabold mt-2 mb-4">What Our Clients Say</h2>
        <p class="text-blue-200 max-w-xl mx-auto">
          Don't just take our word for it — hear from the individuals and business owners who trust us with their finances.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-8 flex flex-col gap-4">
            <div class="flex gap-1 text-yellow-400 text-lg">
              ★★★★★
            </div>
            <p class="text-blue-100 text-sm leading-relaxed italic">"{t.text}"</p>
            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-white/20">
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                {t.initials}
              </div>
              <div>
                <p class="font-bold text-white text-sm">{t.name}</p>
                <p class="text-blue-300 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <span class="text-blue-700 text-sm font-bold uppercase tracking-widest">Get In Touch</span>
        <h2 class="text-4xl font-extrabold text-gray-900 mt-2 mb-4">Contact J&amp;S Tax Accountants</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Ready to get started? Reach out today and one of our accounting professionals will be in touch shortly.
        </p>
      </div>
      <div class="flex flex-col lg:flex-row gap-10">
        <!-- Contact Info -->
        <div class="flex-1 flex flex-col gap-6">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-700 text-xl flex-shrink-0">📍</div>
            <div>
              <p class="font-bold text-gray-900 mb-1">Our Office</p>
              <p class="text-gray-500 text-sm">123 Financial Way, Suite 200<br />Los Angeles, CA 90001</p>
            </div>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-700 text-xl flex-shrink-0">📞</div>
            <div>
              <p class="font-bold text-gray-900 mb-1">Call Us</p>
              <p class="text-gray-500 text-sm">(555) 234-5678</p>
              <p class="text-gray-400 text-xs mt-1">Mon–Fri: 9am – 6pm</p>
            </div>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-700 text-xl flex-shrink-0">✉️</div>
            <div>
              <p class="font-bold text-gray-900 mb-1">Email Us</p>
              <p class="text-gray-500 text-sm">info@jstaxaccountants.com</p>
              <p class="text-gray-400 text-xs mt-1">We respond within 24 hours</p>
            </div>
          </div>
          <div class="bg-blue-700 rounded-2xl p-6 text-white">
            <h3 class="font-bold text-lg mb-2">Tax Season Hours</h3>
            <p class="text-blue-100 text-sm">Jan 15 – Apr 15: Mon–Sat 8am–8pm</p>
            <p class="text-blue-100 text-sm">Sunday: 10am – 4pm</p>
          </div>
        </div>
        <!-- Contact Form -->
        <div class="flex-1 bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Send Us a Message</h3>
          <form class="flex flex-col gap-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="text-sm font-semibold text-gray-700 block mb-1">First Name</label>
                <input
                  type="text"
                  placeholder="John"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors"
                />
              </div>
              <div>
                <label class="text-sm font-semibold text-gray-700 block mb-1">Last Name</label>
                <input
                  type="text"
                  placeholder="Smith"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors"
                />
              </div>
            </div>
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-1">Email Address</label>
              <input
                type="email"
                placeholder="john@example.com"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors"
              />
            </div>
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-1">Phone Number</label>
              <input
                type="tel"
                placeholder="(555) 000-0000"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors"
              />
            </div>
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-1">Service Needed</label>
              <select class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-600 focus:outline-none focus:border-blue-500 transition-colors">
                <option value="">Select a service...</option>
                <option>Tax Preparation</option>
                <option>Bookkeeping</option>
                <option>Business Accounting</option>
                <option>Tax Planning</option>
                <option>IRS Representation</option>
                <option>Financial Consulting</option>
              </select>
            </div>
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-1">Message</label>
              <textarea
                placeholder="Tell us about your needs..."
                rows={4}
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-colors resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="bg-blue-700 hover:bg-blue-800 text-white font-bold py-4 rounded-lg transition-colors mt-1"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-center md:text-left">
          <span class="text-white font-extrabold text-xl">J&amp;S Tax Accountants</span>
          <p class="text-sm mt-1">Trusted financial professionals serving our community.</p>
        </div>
        <nav class="flex gap-6 text-sm">
          <a href="#hero" class="hover:text-white transition-colors">Home</a>
          <a href="#services" class="hover:text-white transition-colors">Services</a>
          <a href="#about" class="hover:text-white transition-colors">About Us</a>
          <a href="#contact" class="hover:text-white transition-colors">Contact</a>
        </nav>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-6 text-center text-xs text-gray-600">
        &copy; {new Date().getFullYear()} J&amp;S Tax Accountants. All rights reserved.
      </div>
    </div>
  </footer>
</Base>