---
import Base from "../layouts/Base.astro";

const services = [
  {
    id: "tax-preparation",
    title: "Tax Preparation",
    icon: "📋",
    description:
      "Comprehensive individual and business tax preparation services. We handle federal, state, and local returns with precision and care, maximizing your deductions while keeping you fully compliant.",
    features: ["Individual Returns", "Business Returns", "Multi-State Filing", "Prior Year Returns"],
  },
  {
    id: "tax-planning",
    title: "Tax Planning",
    icon: "🗓️",
    description:
      "Proactive tax planning strategies tailored to your financial situation. We work with you year-round to minimize your tax liability and prepare for future obligations.",
    features: ["Year-Round Planning", "Retirement Tax Strategy", "Investment Tax Planning", "Life Event Planning"],
  },
  {
    id: "bookkeeping",
    title: "Bookkeeping",
    icon: "📒",
    description:
      "Accurate and timely bookkeeping services for small to mid-sized businesses. We keep your financial records organized so you can focus on growing your business.",
    features: ["Monthly Reconciliation", "Accounts Payable/Receivable", "Financial Reporting", "Cloud-Based Solutions"],
  },
  {
    id: "payroll-services",
    title: "Payroll Services",
    icon: "💼",
    description:
      "Reliable payroll processing to ensure your employees are paid accurately and on time. We handle all payroll tax filings and compliance requirements.",
    features: ["Payroll Processing", "Payroll Tax Filing", "Direct Deposit Setup", "W-2 & 1099 Preparation"],
  },
  {
    id: "business-consulting",
    title: "Business Consulting",
    icon: "📈",
    description:
      "Strategic business consulting to help you make informed financial decisions. From startup formation to growth strategy, we're your trusted financial advisor.",
    features: ["Business Formation", "Cash Flow Analysis", "Budgeting & Forecasting", "Entity Selection"],
  },
  {
    id: "irs-representation",
    title: "IRS Representation",
    icon: "🛡️",
    description:
      "Experienced representation before the IRS and state tax authorities. We advocate on your behalf for audits, appeals, collections, and other tax disputes.",
    features: ["Audit Representation", "Offer in Compromise", "Tax Lien Resolution", "Penalty Abatement"],
  },
];

const process = [
  { step: "01", title: "Initial Consultation", description: "We meet to understand your financial situation, goals, and specific needs." },
  { step: "02", title: "Document Collection", description: "We guide you through gathering all necessary financial documents and records." },
  { step: "03", title: "Analysis & Preparation", description: "Our team carefully analyzes your information and prepares your returns or reports." },
  { step: "04", title: "Review & Delivery", description: "We review everything with you, answer questions, and deliver final documents." },
];

const testimonials = [
  {
    name: "Robert M.",
    role: "Small Business Owner",
    text: "J&S Tax has been handling our business taxes for five years. Their attention to detail and proactive advice has saved us thousands of dollars every year.",
    rating: 5,
  },
  {
    name: "Linda K.",
    role: "Self-Employed Consultant",
    text: "Switching to J&S Tax was the best financial decision I made. They explained everything clearly and found deductions I never knew I qualified for.",
    rating: 5,
  },
  {
    name: "David T.",
    role: "Individual Taxpayer",
    text: "Professional, responsive, and thorough. They handled my complicated tax situation involving multiple states without any issues.",
    rating: 5,
  },
];
---

<Base title="Services — J&S Tax Accountants">
  <!-- Hero Section -->
  <section id="hero" class="relative bg-slate-800 text-white py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-blue-900 opacity-90"></div>
    <div class="absolute inset-0 opacity-10"
      style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 20px 20px;">
    </div>
    <div class="relative max-w-5xl mx-auto px-6 text-center">
      <span class="inline-block bg-blue-600 text-white text-sm font-semibold tracking-widest uppercase px-4 py-1 rounded-full mb-5">
        What We Offer
      </span>
      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
        Our <span class="text-blue-400">Services</span>
      </h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10">
        From tax preparation to business consulting, J&amp;S Tax Accountants provides a full suite of financial services to individuals and businesses across the region.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#services-grid"
          class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors duration-200">
          Explore Services
        </a>
        <a href="#contact"
          class="border border-slate-400 hover:border-white text-slate-300 hover:text-white font-semibold px-8 py-3 rounded-lg transition-colors duration-200">
          Get a Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Intro Banner -->
  <section class="bg-blue-600 py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
        <div>
          <div class="text-4xl font-bold mb-1">15+</div>
          <div class="text-blue-100 text-sm uppercase tracking-wide">Years of Experience</div>
        </div>
        <div>
          <div class="text-4xl font-bold mb-1">500+</div>
          <div class="text-blue-100 text-sm uppercase tracking-wide">Clients Served</div>
        </div>
        <div>
          <div class="text-4xl font-bold mb-1">6</div>
          <div class="text-blue-100 text-sm uppercase tracking-wide">Core Services</div>
        </div>
        <div>
          <div class="text-4xl font-bold mb-1">100%</div>
          <div class="text-blue-100 text-sm uppercase tracking-wide">Client Satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid Section -->
  <section id="services-grid" class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-widest">Full-Service Accounting</span>
        <h2 class="text-4xl font-bold text-slate-800 mt-3 mb-4">Everything You Need Under One Roof</h2>
        <p class="text-slate-500 max-w-2xl mx-auto text-lg">
          We offer a comprehensive range of accounting and tax services designed to serve individuals, self-employed professionals, and businesses of all sizes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div
            id={service.id}
            class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden group border border-gray-100"
          >
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 p-6 flex items-center gap-4">
              <span class="text-4xl">{service.icon}</span>
              <h3 class="text-xl font-bold text-white">{service.title}</h3>
            </div>
            <div class="p-6">
              <p class="text-slate-600 mb-5 leading-relaxed">{service.description}</p>
              <ul class="space-y-2">
                {service.features.map((feature) => (
                  <li class="flex items-center gap-2 text-slate-700 text-sm">
                    <span class="w-5 h-5 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center flex-shrink-0 text-xs font-bold">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
              <div class="mt-6">
                <a
                  href="#contact"
                  class="inline-block w-full text-center bg-blue-50 hover:bg-blue-600 text-blue-700 hover:text-white font-semibold py-2.5 rounded-lg transition-colors duration-200 text-sm"
                >
                  Learn More →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works / Process Section -->
  <section id="process" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-widest">Simple &amp; Transparent</span>
        <h2 class="text-4xl font-bold text-slate-800 mt-3 mb-4">How We Work With You</h2>
        <p class="text-slate-500 max-w-xl mx-auto text-lg">
          Our straightforward process ensures a smooth experience from the first conversation to final delivery.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((item, index) => (
          <div class="relative text-center">
            {index < process.length - 1 && (
              <div class="hidden lg:block absolute top-10 left-[60%] w-full h-0.5 bg-blue-100 z-0"></div>
            )}
            <div class="relative z-10 w-20 h-20 rounded-full bg-blue-600 text-white text-2xl font-bold flex items-center justify-center mx-auto mb-5 shadow-lg shadow-blue-200">
              {item.step}
            </div>
            <h3 class="text-lg font-bold text-slate-800 mb-2">{item.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Image / CTA Banner -->
  <section class="relative py-24 bg-slate-900 overflow-hidden">
    <img
      src="/images/placeholder.jpg"
      alt="Accounting office"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative max-w-4xl mx-auto px-6 text-center text-white">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Not Sure Which Service You Need?
      </h2>
      <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
        Schedule a free, no-obligation consultation with one of our experienced accountants. We'll assess your situation and recommend the right solutions.
      </p>
      <a
        href="#contact"
        class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-10 py-4 rounded-lg text-lg transition-colors duration-200 shadow-xl shadow-blue-900/40"
      >
        Book a Free Consultation
      </a>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-widest">Client Stories</span>
        <h2 class="text-4xl font-bold text-slate-800 mt-3 mb-4">What Our Clients Say</h2>
        <p class="text-slate-500 max-w-xl mx-auto text-lg">
          Don't take our word for it — here's what our clients have to say about working with J&amp;S Tax Accountants.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: testimonial.rating }).map(() => (
                <span class="text-yellow-400 text-lg">★</span>
              ))}
            </div>
            <p class="text-slate-600 italic leading-relaxed mb-6 flex-grow">"{testimonial.text}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
              <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 font-bold flex items-center justify-center flex-shrink-0">
                {testimonial.name.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-slate-800">{testimonial.name}</div>
                <div class="text-slate-400 text-sm">{testimonial.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact / CTA Section -->
  <section id="contact" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Contact Info -->
        <div>
          <span class="text-blue-600 font-semibold text-sm uppercase tracking-widest">Get In Touch</span>
          <h2 class="text-4xl font-bold text-slate-800 mt-3 mb-5">Ready to Get Started?</h2>
          <p class="text-slate-500 text-lg leading-relaxed mb-8">
            Contact J&amp;S Tax Accountants today. Whether you have questions about a specific service or are ready to schedule your first appointment, we're here to help.
          </p>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <span class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 text-lg flex-shrink-0">📍</span>
              <div>
                <div class="font-semibold text-slate-800">Our Office</div>
                <div class="text-slate-500">123 Financial Drive, Suite 200<br/>Springfield, IL 62701</div>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 text-lg flex-shrink-0">📞</span>
              <div>
                <div class="font-semibold text-slate-800">Phone</div>
                <a href="tel:+15555551234" class="text-blue-600 hover:underline">(555) 555-1234</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 text-lg flex-shrink-0">✉️</span>
              <div>
                <div class="font-semibold text-slate-800">Email</div>
                <a href="mailto:info@jstaxaccountants.com" class="text-blue-600 hover:underline">info@jstaxaccountants.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 text-lg flex-shrink-0">🕐</span>
              <div>
                <div class="font-semibold text-slate-800">Business Hours</div>
                <div class="text-slate-500">Mon–Fri: 9:00 AM – 6:00 PM<br/>Sat: 10:00 AM – 2:00 PM</div>
              </div>
            </li>
          </ul>
        </div>

        <!-- Contact Form -->
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 shadow-sm">
          <h3 class="text-2xl font-bold text-slate-800 mb-6">Send Us a Message</h3>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5" for="first-name">First Name</label>
                <input
                  id="first-name"
                  type="text"
                  placeholder="Jane"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5" for="last-name">Last Name</label>
                <input
                  id="last-name"
                  type="text"
                  placeholder="Doe"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5" for="email">Email Address</label>
              <input
                id="email"
                type="email"
                placeholder="jane@example.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5" for="service">Service of Interest</label>
              <select
                id="service"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
              >
                <option value="">Select a service…</option>
                {services.map((s) => (
                  <option value={s.id}>{s.title}</option>
                ))}
                <option value="other">Other / Not Sure</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5" for="message">Message</label>
              <textarea
                id="message"
                rows={4}
                placeholder="Tell us a bit about your situation…"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 rounded-lg transition-colors duration-200 text-lg shadow-md shadow-blue-200"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>